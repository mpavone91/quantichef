{
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/escandallo", "destination": "/escandallo.html" },
    { "source": "/login", "destination": "/auth.html" },
    { "source": "/precios", "destination": "/precios.html" },
    { "source": "/legal", "destination": "/legal.html" },
    { "source": "/contacto", "destination": "/contacto.html" }
  ],
  "crons": [
    {
      "path": "/api/send-trial-reminder",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "api/extract.js": {
      "maxDuration": 120
    },
    "api/extract-recipe.js": {
      "maxDuration": 120
    },
    "api/chat.js": {
      "maxDuration": 30
    }
  }
}
